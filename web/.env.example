# Public site URL (no trailing slash). Used by usePageMeta for canonical / OG URLs.
VITE_PUBLIC_URL=https://your-app.example.com

# Feature flags — toggle pages on/off without code changes
VITE_ENABLE_SUPPORT_PAGE=false
VITE_ENABLE_PRIVACY_PAGE=true
VITE_ENABLE_TERMS_PAGE=true

# Support page donation options (only used when VITE_ENABLE_SUPPORT_PAGE=true)
# VITE_PIX_KEY=your-pix-key
# VITE_BUY_ME_A_COFFEE_URL=https://buymeacoffee.com/yourname
# VITE_BITCOIN_ADDRESS=your-bitcoin-address
