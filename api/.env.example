# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the web frontend (used for CORS and email links)
WEB_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Select the database engine: sqlite (default) or postgres
DATABASE_PROVIDER=sqlite

# SQLite — path to the database file (only used when DATABASE_PROVIDER=sqlite)
DATABASE_PATH=./data/db.sqlite

# PostgreSQL — connection string (required when DATABASE_PROVIDER=postgres)
# DATABASE_URL=postgres://user:password@localhost:5432/starter_app
# DATABASE_PROVIDER=postgres

# ── Email ─────────────────────────────────────────────────────────────────────
# Default dev mode: MailHog via local SMTP (no auth)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@starter.local

# HTTP mode (alternative to SMTP — required on platforms that block SMTP ports).
# EMAIL_HTTP_URL=https://api.resend.com/emails
# EMAIL_HTTP_KEY=re_xxxx

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_AUTH=true
ENABLE_REGISTRATION=true
MAINTENANCE_MODE=false
