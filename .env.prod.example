# Production environment variables template.
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=starter_app
POSTGRES_USER=starter_app
POSTGRES_PASSWORD=change_to_a_strong_password

# DATABASE_URL must match the values above.
# The hostname "db" is the Docker service name.
DATABASE_URL=postgres://starter_app:change_to_a_strong_password@db:5432/starter_app

# ── Application ────────────────────────────────────────────────────────────────
# Public URL where users access the app — used for CORS and email links.
WEB_URL=https://your-app.example.com

EMAIL_FROM=noreply@your-app.example.com
MAGIC_LINK_EXPIRY_MINUTES=15

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_AUTH=true
ENABLE_REGISTRATION=true
MAINTENANCE_MODE=false

# ── Email ──────────────────────────────────────────────────────────────────────
# Choose ONE of the two modes below.

# HTTP mode — required on platforms that block SMTP ports (e.g. Railway).
# Works with any provider that accepts POST JSON with Bearer auth.
# Resend:  EMAIL_HTTP_URL=https://api.resend.com/emails
EMAIL_HTTP_URL=https://api.resend.com/emails
EMAIL_HTTP_KEY=re_xxxx

# SMTP mode — for platforms without port restrictions (VPS, Fly.io, etc.)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_pass
